,0,19.9,22a2.09,2.09,0,0,1,.92,1.86c-.2,1-3.48,3.07-6.29,4.28l-.88.37.07.95a99.42,99.42,0,0,0,3,17.34c2.36,8,.24,12.17.21,12.22l2,1.65c.09-.08,9.3-7.77,19.88-8.58,9.6-.75,14.31,3.43,14.36,3.47a1.19,1.19,0,0,0,.5.28c-.14,2.68-.22,5.45-.22,8.33q0,6.16.44,11.72C49.7,78.1,38.41,81.14,31.23,76.55Zm64.92,25.7C87.36,102.25,83,94,83,63.76c0-30,4.22-38.13,13-38.13s13.18,8.44,13.18,38.49S104.94,102.25,96.15,102.25Zm92.21-38.86a20.72,20.72,0,0,0-.77,4.28c-.24,2.19-.45,4.08-1.65,5.3a6.05,6.05,0,0,1-3.05,1.11,10.94,10.94,0,0,0-2.57.69c-4.58,2.08-9.72,1.67-13.47,1.37-2.74-.22-4.71-.38-5.95.41-7.21,4.6-18.55,1.52-22.7-.74.31-3.8.48-7.81.48-12.05q0-4.12-.2-8a1.38,1.38,0,0,0,.48-.28s4.75-4.22,14.35-3.48c10.59.82,19.79,8.52,19.88,8.59l2-1.65c0-.05-2.14-4.19.22-12.23a98.87,98.87,0,0,0,3-17.35l.07-.94-.87-.38c-2.82-1.2-6.09-3.26-6.3-4.28a2.12,2.12,0,0,1,.92-1.86,6.61,6.61,0,0,0,3.51,1.39h.07A2.71,2.71,0,0,0,178.38,21a6.56,6.56,0,0,0,.21-1.66,1.33,1.33,0,0,0-1.33-1.3h0a1.33,1.33,0,0,0-1.31,1.35,4.75,4.75,0,0,1-.17,1.23,3,3,0,0,1-1.6-.64l-.59-.74a1.9,1.9,0,0,1-.3-1.4c.18-.73,1-1.44,2.3-2.05a5.73,5.73,0,0,1,6.22.82,6.92,6.92,0,0,0,2.31,1.08,5.21,5.21,0,0,1,1,.36c.37.9.11,2.15-.25,3.89a26.5,26.5,0,0,0-.45,10.22c.73,4.51,1.44,7.38,2.07,9.92a69.32,69.32,0,0,1,1.71,8.56C189,57.13,189.23,60.68,188.36,63.39Z"></path>
          </svg>
        </div>
        <p class="schedule-empty-state__eyebrow">Sin resultados por ahora</p>
        <h3 class="schedule-empty-state__title">No encontramos clases para esta búsqueda.</h3>
        <p class="schedule-empty-state__copy">
          Ajusta los filtros o vuelve más tarde para revisar nuevas sesiones, horarios y sucursales disponibles.
        </p>
      </div>
    </div>
  </div>

</section>

<!-- Modal -->
<dialog
  id="class-dialog"
  class="backdrop:bg-black/80 backdrop:backdrop-blur-sm bg-transparent p-0 m-auto rounded-xl shadow-2xl max-w-lg w-[90%]"
>
  <div class="bg-white rounded-xl overflow-hidden relative">
    <button id="close-dialog-btn" class="absolute top-3 right-3 z-10 bg-white/80 hover:bg-white text-gray-800 rounded-full w-8 h-8 flex items-center justify-center font-bold shadow-sm">✕</button>
    <div class="h-32 bg-black w-full relative">
      <div class="absolute bottom-0 left-0 p-4 w-full">
        <p id="d-category" class="text-yellow-400 text-xs uppercase tracking-widest mb-1"></p>
        <h2 id="d-title" class="text-2xl font-bold text-white"></h2>
      </div>
    </div>
    <div class="p-6">
      <p id="d-desc" class="text-gray-600 text-sm mb-4 leading-relaxed"></p>
      <div class="bg-gray-50 rounded-lg p-3 space-y-2 text-sm border border-gray-100">
        <div class="flex justify-between"><span class="text-gray-500">Día</span><span id="d-day" class="font-medium"></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Horario</span><span id="d-time" class="font-medium"></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Duración</span><span id="d-duration" class="font-medium"></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Instructor</span><span id="d-instructor" class="font-medium"></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Sucursal</span><span id="d-branch" class="font-medium"></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Lugares</span><span id="d-spots" class="font-medium"></span></div>
      </div>
      <button id="d-reserve-btn" class="w-full mt-6 bg-yellow-500 text-black font-bold py-3 rounded-lg hover:bg-yellow-400 transition-colors">
        Reservar Clase
      </button>
    </div>
  </div>
</dialog>

<style>
  dialog { border: none; position: fixed; inset: 0; }
  dialog[open] { animation: zoomIn 0.2s ease-out; }
  @keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  .js-class-card[data-filtered="true"] { display: none; }
</style>

<script>
  function init() {
    const dialog = document.getElementById('class-dialog') as HTMLDialogElement;
    const closeBtn = document.getElementById('close-dialog-btn');
    if (!dialog || !closeBtn) return;
    if (dialog.dataset.initialized === 'true') return;
    dialog.dataset.initialized = 'true';

    // Filtros
    const filterBranch = document.getElementById('filter-branch') as HTMLSelectElement;
    const filterCategory = document.getElementById('filter-category') as HTMLSelectElement;
    const emptyState = document.getElementById('schedule-empty-state');
    const gridShell = document.getElementById('schedule-grid-shell');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.js-class-card'));

    function updateEmptyState() {
      if (!emptyState || !gridShell) return;
      const visibleCards = cards.filter(card => card.dataset.filtered !== 'true');
      const hasVisibleCards = visibleCards.length > 0;

      emptyState.classList.toggle('is-hidden', hasVisibleCards);
      gridShell.classList.toggle('schedule-grid-shell--hidden', !hasVisibleCards);
    }

    function applyFilters() {
      const branch = filterBranch.value;
      const category = filterCategory.value;
      cards.forEach(card => {
        const matchBranch = !branch || card.dataset.branch === branch;
        const matchCategory = !category || card.dataset.category === category;
        card.dataset.filtered = (!matchBranch || !matchCategory) ? 'true' : 'false';
      });
      updateEmptyState();
    }

    filterBranch.addEventListener('change', applyFilters);
    filterCategory.addEventListener('change', applyFilters);
    updateEmptyState();

    // Modal
    cards.forEach(card => {
      card.addEventListener('click', () => {
        (document.getElementById('d-title') as HTMLElement).textContent = card.dataset.name || '';
        (document.getElementById('d-category') as HTMLElement).textContent = card.dataset.category || '';
        (document.getElementById('d-desc') as HTMLElement).textContent = card.dataset.desc || '';
        (document.getElementById('d-day') as HTMLElement).textContent = card.dataset.day || '';
        (document.getElementById('d-time') as HTMLElement).textContent = card.dataset.time || '';
        (document.getElementById('d-duration') as HTMLElement).textContent = card.dataset.duration || '';
        (document.getElementById('d-instructor') as HTMLElement).textContent = card.dataset.instructor || '';
        (document.getElementById('d-branch') as HTMLElement).textContent = card.dataset.branch || '';
        const spots = Number(card.dataset.spots);
        (document.getElementById('d-spots') as HTMLElement).textContent = spots === 0 ? 'Sin lugares' : `${spots} disponibles`;
        const btn = document.getElementById('d-reserve-btn') as HTMLButtonElement;
        btn.disabled = spots === 0;
        btn.textContent = spots === 0 ? 'Sin lugares disponibles' : 'Reservar Clase';
        if (!dialog.open) dialog.showModal();
      });
    });

    closeBtn.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .container-astro {
    margin: 0 auto;
    max-width: 88rem;
  }

  h2 {
    font-family: 'BullText-Bold', monospace, sans-serif;
    color: #161616;
    font-size: clamp(2.6rem, 4vw, 4.75rem);
    line-height: 0.95;
    margin-bottom: 2.25rem;
    text-transform: uppercase;
  }

  #filter-branch,
  #filter-category {
    color: black
  }

  .schedule-header {
    margin-bottom: 2.25rem;
  }

  .schedule-grid-shell--hidden {
    display: none;
  }

  .schedule-empty-state {
    display: grid;
    place-items: center;
    text-align: center;
    gap: 0.9rem;
    margin: 1rem auto 0;
    padding: 3.25rem 1.5rem;
    max-width: 42rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top, rgba(246, 181, 0, 0.14), transparent 46%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 246, 246, 0.98));
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.06);
  }

  .schedule-empty-state.is-hidden {
    display: none;
  }

  .schedule-empty-state__art {
    width: min(11rem, 55vw);
  }

  .no-result--logo {
    width: 100%;
    height: auto;
    display: block;
  }

  .schedule-empty-state__eyebrow {
    margin: 0;
    color: #b28700;
    font-size: 0.8rem;
    font-family: 'BullText-Bold', monospace, sans-serif;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .schedule-empty-state__title {
    margin: 0;
    color: #111111;
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    line-height: 1.05;
    text-transform: none;
  }

  .schedule-empty-state__copy {
    margin: 0;
    max-width: 31rem;
    color: #5b5b5b;
    font-size: 0.98rem;
    line-height: 1.65;
  }
</style>
