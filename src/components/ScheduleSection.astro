---
import type { GymClass } from '../data/classes';

const { sessions = [] } = Astro.props as { sessions: GymClass[] };
console.log('sessions recibidas:', sessions);
---

<section class="p-8 bg-gray-50 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8 text-center">Horario Simplificado</h1>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {sessions.map((session) => (
        <button 
          class="js-class-card bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-all text-left border-l-4 border-yellow-500 group"
          data-name={session.name}
          data-time={session.time}
          data-instructor={session.instructor}
          data-branch={session.branch}
          data-desc={session.description}
        >
          <h3 class="font-bold text-xl mb-1 group-hover:text-yellow-600 transition-colors">{session.name}</h3>
          <p class="text-gray-500 text-sm mb-2">{session.time}</p>
          <span class="inline-block bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded">
            {session.branch}
          </span>
        </button>
      ))}
    </div>
  </div>
</section>

<dialog 
  id="class-dialog" 
  class="backdrop:bg-black/80 backdrop:backdrop-blur-sm bg-transparent p-0 m-auto rounded-xl shadow-2xl max-w-lg w-[90%] open:animate-fade-in"
>
  <div class="bg-white rounded-xl overflow-hidden relative">
    
    <button 
      id="close-dialog-btn"
      class="absolute top-3 right-3 z-10 bg-white/80 hover:bg-white text-gray-800 rounded-full w-8 h-8 flex items-center justify-center transition-colors font-bold shadow-sm"
    >
      ✕
    </button>

    <div class="h-32 bg-gray-200 w-full object-cover relative">
       <div class="absolute bottom-0 left-0 p-4 bg-gradient-to-t from-black/60 to-transparent w-full">
         <h2 id="d-title" class="text-2xl font-bold text-white leading-none"></h2>
       </div>
    </div>

    <div class="p-6">
      <p id="d-desc" class="text-gray-600 text-sm mb-4 leading-relaxed"></p>

      <div class="bg-gray-50 rounded-lg p-3 space-y-2 text-sm border border-gray-100">
        <div class="flex justify-between">
          <span class="text-gray-500"><i class="fas fa-clock w-5 text-yellow-600"></i> Horario</span>
          <span id="d-time" class="font-medium text-gray-900"></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500"><i class="fas fa-user w-5 text-yellow-600"></i> Instructor</span>
          <span id="d-instructor" class="font-medium text-gray-900"></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500"><i class="fas fa-map-marker-alt w-5 text-yellow-600"></i> Sucursal</span>
          <span id="d-branch" class="font-medium text-gray-900"></span>
        </div>
      </div>

      <button class="w-full mt-6 bg-yellow-500 text-black font-bold py-3 rounded-lg hover:bg-yellow-400 transition-colors shadow-md">
        Reservar Clase
      </button>
    </div>
  </div>
</dialog>

<style>
  /* Animación suave al abrir */
  dialog[open] {
    animation: zoomIn 0.2s ease-out;
  }
  @keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  
  /* Reset básico para el dialog */
  dialog {
    border: none; /* Quitar bordes por defecto del navegador */
    position: fixed; /* Asegurar posición fija */
    inset: 0; /* Centrado automático nativo */
  }
</style>

<script>
  // Script simplificado y robusto
  function initDialog() {
    const dialog = document.getElementById('class-dialog') as HTMLDialogElement;
    const closeBtn = document.getElementById('close-dialog-btn');
    const cards = document.querySelectorAll<HTMLElement>('.js-class-card');

    // TypeScript check
    if (!dialog || !closeBtn) return;
    if (dialog.dataset.initialized === 'true') return;
    dialog.dataset.initialized = 'true';

    // Función para abrir
    const openDialog = (card: HTMLElement) => {
      // 1. Rellenar datos
      const title = card.getAttribute('data-name') || 'Clase';
      const time = card.getAttribute('data-time') || '--:--';
      const instructor = card.getAttribute('data-instructor') || 'Por confirmar';
      const branch = card.getAttribute('data-branch') || '';
      const desc = card.getAttribute('data-desc') || 'Sin descripción disponible.';

      const elTitle = document.getElementById('d-title');
      const elDesc = document.getElementById('d-desc');
      const elTime = document.getElementById('d-time');
      const elInstructor = document.getElementById('d-instructor');
      const elBranch = document.getElementById('d-branch');

      if(elTitle) elTitle.textContent = title;
      if(elDesc) elDesc.textContent = desc;
      if(elTime) elTime.textContent = time;
      if(elInstructor) elInstructor.textContent = instructor;
      if(elBranch) elBranch.textContent = branch;

      // 2. ABRIR NATIVAMENTE
      // .showModal() es la clave: pone el elemento en el Top Layer (encima de todo CSS)
      // y crea el backdrop automáticamente.
      if (!dialog.open) {
        dialog.showModal();
      }
    };

    // Función cerrar
    const closeDialog = () => {
      dialog.close(); // Método nativo
    };

    // Listeners
    cards.forEach(card => {
      card.addEventListener('click', () => openDialog(card));
    });

    closeBtn.addEventListener('click', closeDialog);

    // Cerrar al hacer click fuera (en el backdrop)
    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      const isInDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
        rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
      if (!isInDialog) {
        dialog.close();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDialog);
  } else {
    initDialog();
  }
  document.addEventListener('astro:page-load', initDialog);
</script>
