---
import HeroSlider from './HeroSlider.astro';

const slides = [
  {
    type: "video",
    src: "/media/hero-video.mp4",
    title: "Entrena sin límites",
    subtitle: "Gimnasio abierto 24 horas, 365 días",
    ctaLabel: "Ver membresías",
  },
  {
    type: "image",
    src: "/media/banner249.png",
    ctaLabel: "Ver membresías",
    title: "Venta espacial pambolera",
  },
  {
    type: "image",
    src: "/media/hero-image.jpg",
    titleImage: "/media/badge-promo.png",
    title: "Tu mejor versión",
    subtitle: "Fuerza, cardio y resultados reales",
    ctaLabel: "Inscribirme ahora",
    ctaHref: "/#inscribirme"
  }
];
---

<header class="relative">
  <HeroSlider slides={slides} />
</header>
