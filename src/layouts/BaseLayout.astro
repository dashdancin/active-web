---
import '../styles/global.css';
const { title = 'Active 24' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body class="bg-black/90 backdrop-blur-lg text-white">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --section-title-size: clamp(1.5rem, 3.2vw, 2.75rem);
    --section-title-line-height: 0.98;
  }

  /* Declaración de la fuente */
  @font-face {
    font-family: 'BullText-Regular';
    /* Nota: La ruta empieza con '/' porque está en public */
    src: url('/fonts/BullText-Regular.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap; /* Importante para rendimiento */
  }

  /* --- FUENTE 1: TÍTULOS (Strong) --- */
@font-face {
  font-family: 'BullText-Bold'; /* Nombre compartido */
  src: url('/fonts/BullText-Bold.woff2') format('woff2');
  font-weight: 700; /* Bold */
  font-style: normal;
  font-display: swap;
}

/* --- FUENTE 2: TEXTO Medium (Inter) --- */
@font-face {
  font-family: 'BullText-Medium'; /* Nombre compartido */
  src: url('/fonts/BullText-Medium.woff2') format('woff2');
  font-weight: 400; /* Normal */
  font-style: normal;
  font-display: swap;
}


  /* Uso por defecto */
body {
  font-family: 'BullText-Regular', monospace, sans-serif;
}
</style>
