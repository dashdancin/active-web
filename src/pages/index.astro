import Experience from "../components/Experience.astro";
import BranchShowcase from "../components/BranchShowcase.astro";
import LeadFormSection from "../components/LeadFormSection.astro";
import MembershipSection from "../components/MembershipSection.astro";
import NewsletterSection from "../components/NewsletterSection.astro";
import Footer from "../components/Footer.astro";

// Personalizar redes sociales (opcional)
const customSocialLinks = [
  {
    name: "Facebook",
    url: "https://www.facebook.com/active24gym",
    icon: "fab fa-facebook-f"
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/active24gym",
    icon: "fab fa-instagram"
  },
  {
    name: "TikTok",
    url: "https://www.tiktok.com/@active24gym",
