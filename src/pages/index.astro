---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import AboutSection from "../components/AboutSection.astro";
import Experience from "../components/Experience.astro";
import BranchShowcase from "../components/BranchShowcase.astro";
import LeadFormSection from "../components/LeadFormSection.astro";
import MembershipSection from "../components/MembershipSection.astro";
import Footer from "../components/Footer.astro";
import ScheduleSection from '@/components/ScheduleSection.astro';
import { classes } from '@/data/classes';


// Personalizar redes sociales (opcional)
const customSocialLinks = [
  {
    name: "Facebook",
    url: "https://www.facebook.com/active24gym",
    icon: "fab fa-facebook-f"
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/active24gym",
    icon: "fab fa-instagram"
  },
  {
    name: "TikTok",
    url: "https://www.tiktok.com/@active24gym",
    icon: "fab fa-tiktok"
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/company/active24",
    icon: "fab fa-linkedin-in"
  }
];
---

<BaseLayout title="Active 24 | Gimnasio 24 horas">
  <Header />
  
  <AboutSection />
  <Experience />
  <BranchShowcase />
  <MembershipSection />
  <ScheduleSection sessions={classes} />
  <LeadFormSection />
  <Footer />
</BaseLayout>
