---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ScheduleSection from '@/components/ScheduleSection.astro';
import { classes } from '@/data/classes.ts';
import Footer from "@/components/Footer.astro";
---

<BaseLayout title="Horario de Clases | Active 24">
  <PageHeader
    eyebrow="Calendario Active 24"
    title="Horario de clases"
    subtitle="Consulta la programación semanal, explora por sucursal y encuentra el horario que mejor se acomode a tu ritmo."
  />

  <ScheduleSection sessions={classes} />

  <Footer />
</BaseLayout>
